# ─── Invoice to Odoo Configuration ────────────────────────────────
# Copy this to .env and fill in your values

# ─── Telegram Bot ─────────────────────────────────────────────────
# 1. Open Telegram, search @BotFather
# 2. Send /newbot → pick a name → get token
# 3. Paste token here
TELEGRAM_TOKEN=your_bot_token_here

# ─── Ollama ───────────────────────────────────────────────────────
# URL where Ollama is running
OLLAMA_URL=http://localhost:11434

# Vision model to use. Options:
#   llava          — good balance (needs ~8GB VRAM)
#   llava:13b      — better quality (needs ~16GB VRAM)
#   minicpm-v      — lightweight (needs ~4GB VRAM) ← recommended for laptops
#   llama3.2-vision — latest, good quality (needs ~8GB VRAM)
#   bakllava       — alternative
OLLAMA_MODEL=llava

# Custom extraction prompt (leave empty for default)
EXTRACTION_PROMPT=

# ─── Watch Folder (optional, for run.py batch mode) ───────────────
WATCH_FOLDER=/mnt/c/Users/kusum/Downloads

# ─── Odoo 13 ──────────────────────────────────────────────────────
ODOO_URL=http://localhost:8069
ODOO_DB=odoo
ODOO_USERNAME=admin
ODOO_PASSWORD=your_password_here

# ─── Odoo Accounting Codes ────────────────────────────────────────
# Chart of accounts codes — adjust to match YOUR Odoo chart
ODOO_EXPENSE_ACCOUNT=211000
ODOO_PAYABLE_ACCOUNT=200000
ODOO_RECEIVABLE_ACCOUNT=120000

# Default tax ID (leave empty to skip tax). Get from Odoo:
#   Settings → Taxes → pick a purchase tax → note its ID
ODOO_DEFAULT_TAX_ID=
